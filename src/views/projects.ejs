<%- include('partials/header') %>
<%- include('partials/navigation') %>

<% if (action === 'new' || action === 'edit') { %>
  <!-- CREATE OR EDIT PROJECT FORM -->
  <div class="bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm max-w-4xl mx-auto space-y-6">
    <div class="flex items-center justify-between border-b border-slate-150 pb-5">
      <h3 class="font-extrabold text-xl text-slate-900 flex items-center gap-2">
        <i class="fa-solid fa-building-circle-check text-primary-500"></i>
        <%= action === 'new' ? 'Add Featured Project' : 'Edit Project Details' %>
      </h3>
      <a href="/admin/projects" class="text-xs font-bold text-slate-500 hover:text-slate-700 uppercase tracking-widest transition">
        <i class="fa-solid fa-arrow-left mr-1"></i> Back to List
      </a>
    </div>

    <form action="<%= action === 'new' ? '/admin/projects/create' : '/admin/projects/' + project._id + '/edit' %>" method="POST" enctype="multipart/form-data" class="space-y-6">
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="md:col-span-2">
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Project Name Title</label>
          <input type="text" name="title" id="proj-title" required value="<%= action === 'edit' ? project.title : '' %>"
                 class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Unique URL Slug</label>
          <input type="text" name="slug" id="proj-slug" required placeholder="e.g. vaikunth-homes" value="<%= action === 'edit' ? project.slug : '' %>"
                 class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-mono text-xs">
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Project Development Type</label>
          <input type="text" name="projectType" required placeholder="e.g. Premium Plotted Development" value="<%= action === 'edit' ? project.projectType : 'Premium Plotted Development' %>"
                 class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
        </div>

        <div class="md:col-span-2">
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Project Copywriting Description</label>
          <textarea name="description" rows="5" required 
                    class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500"><%= action === 'edit' ? project.description : '' %></textarea>
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Development Status</label>
          <select name="status" required class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-semibold bg-white">
            <option value="ONGOING" <%= action === 'edit' && project.status === 'ONGOING' ? 'selected' : '' %>>ONGOING</option>
            <option value="COMPLETED" <%= action === 'edit' && project.status === 'COMPLETED' ? 'selected' : '' %>>COMPLETED</option>
          </select>
        </div>

        <div>
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Location Area</label>
          <input type="text" name="location" required placeholder="e.g. Jahangirabad, Surat" value="<%= action === 'edit' ? project.location : '' %>"
                 class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
        </div>

        <div class="md:col-span-2">
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Detailed Site Address</label>
          <input type="text" name="address" required placeholder="Full street plot address..." value="<%= action === 'edit' ? project.address : '' %>"
                 class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
        </div>

        <div class="md:col-span-2 space-y-2">
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Amenities List (Separate with commas)</label>
          <input type="text" name="amenities" placeholder="e.g. Clubhouse, 24/7 Security, Swimming Pool" value="<%= action === 'edit' && project.amenities ? project.amenities.join(', ') : '' %>"
                 class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
        </div>

        <div class="md:col-span-2">
          <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Upload Project Photos</label>
          <input type="file" name="images" multiple accept="image/*"
                 class="w-full text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer">
          <% if (action === 'edit' && project.images && project.images.length > 0) { %>
            <div class="mt-4 space-y-2">
              <span class="block text-xs text-slate-400 font-semibold">Current Images (Uncheck to delete):</span>
              <div class="flex flex-wrap gap-3">
                <% project.images.forEach(img => { %>
                  <label class="relative group cursor-pointer block border border-slate-200 rounded-xl overflow-hidden h-16 w-16 shadow-sm">
                    <img src="<%= img %>" class="h-full w-full object-cover">
                    <input type="checkbox" name="existingImages" value="<%= img %>" checked 
                           class="absolute top-1 left-1 rounded focus:ring-primary-500 text-primary-600">
                  </label>
                <% }) %>
              </div>
            </div>
          <% } %>
        </div>
      </div>

      <div class="border-t border-slate-150 pt-6 flex items-center justify-end gap-3">
        <a href="/admin/projects" class="px-5 py-3 rounded-2xl text-sm font-bold text-slate-500 hover:bg-slate-100 transition">Cancel</a>
        <button type="submit" class="px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-2xl text-sm font-bold transition shadow-lg shadow-primary-600/10 flex items-center gap-2">
          <i class="fa-solid fa-cloud-arrow-up"></i>
          <span><%= action === 'new' ? 'Create Project' : 'Save Modifications' %></span>
        </button>
      </div>

    </form>
  </div>

  <script>
    // Automatic Slug Generation
    const titleInput = document.getElementById('proj-title');
    const slugInput = document.getElementById('proj-slug');
    if (titleInput && slugInput && '<%= action %>' === 'new') {
      titleInput.addEventListener('input', () => {
        slugInput.value = titleInput.value
          .toLowerCase()
          .replace(/[^a-z0-9\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/-+/g, '-');
      });
    }
  </script>
<% } else { %>
  <!-- PROJECTS LIST VIEW -->
  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-2xl font-extrabold text-slate-900 tracking-tight">Featured Projects</h2>
      <p class="text-sm text-slate-500 mt-1">Manage ongoing and completed development projects, amenities, and brochures.</p>
    </div>
    <a href="/admin/projects?action=new" class="px-5 py-3.5 bg-primary-600 hover:bg-primary-500 text-white rounded-2xl text-sm font-bold transition shadow-lg shadow-primary-600/10 flex items-center gap-2">
      <i class="fa-solid fa-plus text-xs"></i> Add Featured Project
    </a>
  </div>

  <section class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden flex flex-col">
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-slate-50 text-slate-400 text-xs font-bold uppercase tracking-wider border-b border-slate-200">
            <th class="py-4 px-6">Project Info</th>
            <th class="py-4 px-6">Location</th>
            <th class="py-4 px-6">Category</th>
            <th class="py-4 px-6">Status</th>
            <th class="py-4 px-6 text-center">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-150">
          <% if (projects && projects.length > 0) { %>
            <% projects.forEach(proj => { %>
              <tr class="hover:bg-slate-50/50 text-slate-700 text-sm transition">
                <td class="py-4 px-6">
                  <div class="flex items-center gap-4">
                    <img src="<%= proj.images && proj.images[0] ? proj.images[0] : '/image.png' %>" class="h-12 w-12 rounded-xl object-cover border border-slate-200">
                    <div>
                      <span class="font-bold text-slate-900 block leading-snug"><%= proj.title %></span>
                      <span class="font-mono text-[10px] text-slate-400 block mt-0.5">slug: <%= proj.slug %></span>
                    </div>
                  </div>
                </td>
                <td class="py-4 px-6 align-top">
                  <div class="space-y-0.5 mt-1">
                    <span class="font-semibold text-slate-800 block"><%= proj.location %></span>
                    <span class="text-xs text-slate-400 block"><%= proj.address %></span>
                  </div>
                </td>
                <td class="py-4 px-6 align-top font-medium text-slate-600">
                  <div class="mt-1">
                    <%= proj.projectType %>
                  </div>
                </td>
                <td class="py-4 px-6 align-top">
                  <div class="mt-1">
                    <% if (proj.status === 'COMPLETED') { %>
                      <span class="inline-flex items-center rounded-full bg-emerald-50 px-2.5 py-0.5 text-xs font-bold text-emerald-700 border border-emerald-100">COMPLETED</span>
                    <% } else { %>
                      <span class="inline-flex items-center rounded-full bg-amber-50 px-2.5 py-0.5 text-xs font-bold text-amber-700 border border-amber-100">ONGOING</span>
                    <% } %>
                  </div>
                </td>
                <td class="py-4 px-6 text-center align-top shrink-0">
                  <div class="flex items-center justify-center gap-1.5 mt-1">
                    <a href="/admin/projects?action=edit&id=<%= proj._id %>" 
                       class="h-9 w-9 bg-slate-50 text-slate-500 border border-slate-200 rounded-xl hover:text-primary-600 hover:border-primary-200 hover:bg-primary-50 flex items-center justify-center transition" 
                       title="Edit Project">
                      <i class="fa-solid fa-pen text-xs"></i>
                    </a>
                    <a href="/admin/projects/<%= proj._id %>/delete" 
                       onclick="return confirm('Remove this project entry permanent?')"
                       class="h-9 w-9 bg-slate-50 text-slate-500 border border-slate-200 rounded-xl hover:text-red-600 hover:border-red-200 hover:bg-red-50 flex items-center justify-center transition" 
                       title="Remove Project">
                      <i class="fa-solid fa-trash-can text-xs"></i>
                    </a>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="5" class="text-center py-16 text-slate-400 italic">No projects listed yet. Start by clicking Add Featured Project above.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>
<% } %>

<%- include('partials/footer') %>
