<%- include('partials/header') %>
<%- include('partials/navigation') %>

<div>
  <h2 class="text-2xl font-extrabold text-slate-900 tracking-tight">Website Content & SEO Editor</h2>
  <p class="text-sm text-slate-500 mt-1">Configure homepage details, about descriptions, contact info, and individual page SEO titles/descriptions.</p>
</div>

<!-- Tabs selector menu -->
<div class="flex flex-wrap border-b border-slate-200" id="tabs-menu">
  <button onclick="switchTab('tab-home')" class="tab-btn border-b-2 border-primary-600 text-primary-600 font-bold px-6 py-3.5 text-sm transition">Homepage Banner</button>
  <button onclick="switchTab('tab-intro')" class="tab-btn border-b-2 border-transparent text-slate-500 hover:text-slate-700 font-semibold px-6 py-3.5 text-sm transition">Introduction Video</button>
  <button onclick="switchTab('tab-about')" class="tab-btn border-b-2 border-transparent text-slate-500 hover:text-slate-700 font-semibold px-6 py-3.5 text-sm transition">About Us Story</button>
  <button onclick="switchTab('tab-contact')" class="tab-btn border-b-2 border-transparent text-slate-500 hover:text-slate-700 font-semibold px-6 py-3.5 text-sm transition">Contact & Socials</button>
  <button onclick="switchTab('tab-seo')" class="tab-btn border-b-2 border-transparent text-slate-500 hover:text-slate-700 font-semibold px-6 py-3.5 text-sm transition">SEO Search Meta</button>
</div>

<!-- 1. HOMEPAGE TAB -->
<div id="tab-home" class="tab-content bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm space-y-6">
  <h3 class="font-bold text-lg text-slate-900"><i class="fa-solid fa-home text-primary-500 mr-1.5"></i> Homepage Hero Info</h3>
  <form action="/admin/content/home" method="POST" enctype="multipart/form-data" class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Kicker Tagline</label>
        <input type="text" name="kicker" value="<%= content.home.kicker %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Headline Title</label>
        <input type="text" name="title" value="<%= content.home.title %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div class="md:col-span-2">
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Hero Description Paragraph</label>
        <textarea name="description" rows="4" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500"><%= content.home.description %></textarea>
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Primary CTA Button Label</label>
        <input type="text" name="primaryLabel" value="<%= content.home.primaryLabel %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Secondary CTA Button Label</label>
        <input type="text" name="secondaryLabel" value="<%= content.home.secondaryLabel %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>

      <!-- Upload Hero Image -->
      <div class="md:col-span-2 border-t border-slate-100 pt-5">
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Hero Cover Image (Upload Photo)</label>
        <input type="file" name="image" accept="image/*" class="w-full text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer">
        <input type="hidden" name="existingImage" value="<%= content.home.image %>">
        <% if (content.home.image) { %>
          <div class="mt-3 flex items-center gap-4">
            <img src="<%= content.home.image %>" class="h-20 w-32 object-cover rounded-xl border border-slate-200 shadow-sm">
            <span class="text-xs text-slate-400 font-mono"><%= content.home.image %></span>
          </div>
        <% } %>
      </div>
    </div>
    <div class="border-t border-slate-150 pt-5 flex justify-end">
      <button type="submit" class="px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-2xl text-sm font-bold transition shadow-lg shadow-primary-600/10">Save Homepage Copy</button>
    </div>
  </form>
</div>

<!-- 2. INTRODUCTION VIDEO TAB -->
<div id="tab-intro" class="tab-content hidden bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm space-y-6">
  <h3 class="font-bold text-lg text-slate-900"><i class="fa-solid fa-circle-play text-primary-500 mr-1.5"></i> Homepage Intro Video Section</h3>
  <form action="/admin/content/introduction" method="POST" enctype="multipart/form-data" class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Video Link URL (e.g. YouTube)</label>
        <input type="text" name="videoUrl" value="<%= content.introduction ? content.introduction.videoUrl : 'https://www.youtube.com/' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Video Thumbnail Cover Image (Upload Photo)</label>
        <input type="file" name="videoPreviewImage" accept="image/*" class="w-full text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer">
        <input type="hidden" name="existingVideoPreviewImage" value="<%= content.introduction ? content.introduction.videoPreviewImage : '' %>">
        <% if (content.introduction && content.introduction.videoPreviewImage) { %>
          <div class="mt-3 flex items-center gap-4">
            <img src="<%= content.introduction.videoPreviewImage %>" class="h-16 w-28 object-cover rounded-xl border border-slate-200 shadow-sm">
            <span class="text-xs text-slate-400 font-mono"><%= content.introduction.videoPreviewImage %></span>
          </div>
        <% } %>
      </div>
      <div class="md:col-span-2">
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Section Kicker / Title</label>
        <input type="text" name="title" value="<%= content.introduction ? content.introduction.title : 'Welcome to Shree Jalaram' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div class="md:col-span-2">
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Introduction Description Paragraph</label>
        <textarea name="description" rows="3" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500"><%= content.introduction ? content.introduction.description : 'Established in 2007, Shree Jalaram Estate Agency specializes in open plot advisory and facilitation...' %></textarea>
      </div>
      <div class="md:col-span-2">
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Checkmark Bullet Points (Separate with commas)</label>
        <input type="text" name="points" value="<%= content.introduction && content.introduction.points ? content.introduction.points.join(', ') : 'Trusted by 5000+ clients, RERA verified projects, Expert real estate guidance in Surat, Prime locations and smart investments' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div class="md:col-span-2">
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Highlights / Badges (Separate with commas)</label>
        <input type="text" name="tags" value="<%= content.introduction && content.introduction.tags ? content.introduction.tags.join(', ') : 'Since 2007, Transparent Dealings, Client-first Approach' %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
    </div>
    <div class="border-t border-slate-150 pt-5 flex justify-end">
      <button type="submit" class="px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-2xl text-sm font-bold transition shadow-lg shadow-primary-600/10">Save Intro Section</button>
    </div>
  </form>
</div>

<!-- 3. ABOUT US STORY TAB -->
<div id="tab-about" class="tab-content hidden bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm space-y-6">
  <h3 class="font-bold text-lg text-slate-900"><i class="fa-solid fa-address-card text-primary-500 mr-1.5"></i> About Us Story Content</h3>
  <form action="/admin/content/about" method="POST" enctype="multipart/form-data" class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Kicker Tagline</label>
        <input type="text" name="kicker" value="<%= content.about.kicker %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Headline Title</label>
        <input type="text" name="title" value="<%= content.about.title %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div class="md:col-span-2">
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Introduction Paragraph</label>
        <textarea name="intro" rows="3" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500"><%= content.about.intro %></textarea>
      </div>
      <div class="md:col-span-2">
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Detailed About Us Body Copy</label>
        <textarea name="details" rows="4" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500"><%= content.about.details %></textarea>
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Hero Main Image (Upload Photo)</label>
        <input type="file" name="heroImage" accept="image/*" class="w-full text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer">
        <input type="hidden" name="existingHeroImage" value="<%= content.about.heroImage %>">
        <% if (content.about.heroImage) { %>
          <div class="mt-3 flex items-center gap-4">
            <img src="<%= content.about.heroImage %>" class="h-16 w-24 object-cover rounded-xl border border-slate-200 shadow-sm">
            <span class="text-xs text-slate-400 font-mono"><%= content.about.heroImage %></span>
          </div>
        <% } %>
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Inset Logo Image (Upload Photo)</label>
        <input type="file" name="insetImage" accept="image/*" class="w-full text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-semibold file:bg-primary-50 file:text-primary-700 hover:file:bg-primary-100 cursor-pointer">
        <input type="hidden" name="existingInsetImage" value="<%= content.about.insetImage %>">
        <% if (content.about.insetImage) { %>
          <div class="mt-3 flex items-center gap-4">
            <img src="<%= content.about.insetImage %>" class="h-16 w-24 object-contain rounded-xl border border-slate-200 shadow-sm bg-slate-50 p-1">
            <span class="text-xs text-slate-400 font-mono"><%= content.about.insetImage %></span>
          </div>
        <% } %>
      </div>

      <!-- Stats section -->
      <div class="md:col-span-2 border-t border-slate-100 pt-5 space-y-4">
        <h4 class="font-bold text-slate-800 text-sm"><i class="fa-solid fa-list-ol text-slate-450 mr-1"></i> Story Statistic Counters</h4>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-3 p-4 bg-slate-50 rounded-2xl border border-slate-150">
            <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Stat 1</span>
            <input type="text" name="stats_0_val" value="<%= content.about.stats && content.about.stats[0] ? content.about.stats[0].value : '100+' %>" placeholder="value e.g. 100+" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm bg-white font-semibold">
            <input type="text" name="stats_0_lbl" value="<%= content.about.stats && content.about.stats[0] ? content.about.stats[0].label : 'Delivered Projects' %>" placeholder="label e.g. Delivered Projects" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-xs bg-white">
          </div>

          <div class="space-y-3 p-4 bg-slate-50 rounded-2xl border border-slate-150">
            <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Stat 2</span>
            <input type="text" name="stats_1_val" value="<%= content.about.stats && content.about.stats[1] ? content.about.stats[1].value : '14+ Years' %>" placeholder="value e.g. 14+ Years" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm bg-white font-semibold">
            <input type="text" name="stats_1_lbl" value="<%= content.about.stats && content.about.stats[1] ? content.about.stats[1].label : 'of Industry Excellence' %>" placeholder="label e.g. of Industry Excellence" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-xs bg-white">
          </div>

          <div class="space-y-3 p-4 bg-slate-50 rounded-2xl border border-slate-150">
            <span class="block text-xs font-bold text-slate-400 uppercase tracking-wider">Stat 3</span>
            <input type="text" name="stats_2_val" value="<%= content.about.stats && content.about.stats[2] ? content.about.stats[2].value : '25' %>" placeholder="value e.g. 25" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-sm bg-white font-semibold">
            <input type="text" name="stats_2_lbl" value="<%= content.about.stats && content.about.stats[2] ? content.about.stats[2].label : 'Award-winning Agents' %>" placeholder="label e.g. Award-winning Agents" class="w-full rounded-xl border border-slate-200 px-3 py-2 text-xs bg-white">
          </div>
        </div>
      </div>
    </div>
    <div class="border-t border-slate-150 pt-5 flex justify-end">
      <button type="submit" class="px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-2xl text-sm font-bold transition shadow-lg shadow-primary-600/10">Save About Copy</button>
    </div>
  </form>
</div>

<!-- 4. CONTACT & SOCIALS TAB -->
<div id="tab-contact" class="tab-content hidden bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm space-y-6">
  <h3 class="font-bold text-lg text-slate-900"><i class="fa-solid fa-address-book text-primary-500 mr-1.5"></i> Contact & Social Profiles Details</h3>
  <form action="/admin/content/contact" method="POST" class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Inquiry E-mail Address</label>
        <input type="email" name="email" value="<%= content.contact.email %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Office Hotline Phone Number</label>
        <input type="text" name="phone" value="<%= content.contact.phone %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div class="md:col-span-2">
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Physical Office Address Text</label>
        <input type="text" name="address" value="<%= content.contact.address %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      
      <div class="border-t border-slate-100 pt-5 md:col-span-2">
        <h4 class="font-bold text-slate-800 text-sm mb-4"><i class="fa-solid fa-share-nodes text-slate-450 mr-1"></i> Social Network Paths</h4>
      </div>

      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2"><i class="fa-brands fa-whatsapp text-green-500 mr-1"></i> WhatsApp Message link</label>
        <input type="text" name="whatsapp" value="<%= content.contact.whatsapp %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2"><i class="fa-brands fa-facebook text-blue-600 mr-1"></i> Facebook Page link</label>
        <input type="text" name="facebook" value="<%= content.contact.facebook %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2"><i class="fa-brands fa-instagram text-pink-600 mr-1"></i> Instagram Handle link</label>
        <input type="text" name="instagram" value="<%= content.contact.instagram %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
      <div>
        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2"><i class="fa-brands fa-youtube text-red-600 mr-1"></i> YouTube Channel link</label>
        <input type="text" name="youtube" value="<%= content.contact.youtube %>" class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-medium">
      </div>
    </div>
    <div class="border-t border-slate-150 pt-5 flex justify-end">
      <button type="submit" class="px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-2xl text-sm font-bold transition shadow-lg shadow-primary-600/10">Save Contacts Details</button>
    </div>
  </form>
</div>

<!-- 4. SEO SEARCH META TAB -->
<div id="tab-seo" class="tab-content hidden bg-white border border-slate-200 rounded-3xl p-6 md:p-8 shadow-sm space-y-6">
  <h3 class="font-bold text-lg text-slate-900"><i class="fa-solid fa-search text-primary-500 mr-1.5"></i> Page Specific Search Engine Configurations</h3>
  
  <form action="/admin/content/seo" method="POST" class="space-y-6">
    <div class="divide-y divide-slate-150 space-y-6">
      
      <% 
        const friendlyRouteNames = {
          home: 'Homepage',
          projects: 'Featured Projects',
          aboutus: 'About Our Agency',
          contactus: 'Contact Us',
          search: 'Properties Search',
          residential: 'Residential Collection',
          commercial: 'Commercial Collection',
          reviews: 'Customer Reviews'
        };
      %>
      
      <% Object.entries(friendlyRouteNames).forEach(([key, label], idx) => { %>
        <div class="<%= idx > 0 ? 'pt-6' : '' %> space-y-4">
          <div class="flex items-center gap-2">
            <span class="h-6 w-6 bg-slate-150 text-slate-650 rounded-lg flex items-center justify-center font-bold text-xs"><%= idx + 1 %></span>
            <h4 class="font-bold text-slate-800 text-base"><%= label %> SEO Settings</h4>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label class="block text-xs font-bold text-slate-405 uppercase tracking-wider mb-2">Meta Title Tag (50-60 characters)</label>
              <input type="text" name="seo[<%= key %>][title]" value="<%= content.seo[key] ? content.seo[key].title : '' %>"
                     class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm outline-none focus:border-primary-500 font-semibold text-slate-800">
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-405 uppercase tracking-wider mb-2">Meta Description Snippet (150-160 characters)</label>
              <textarea name="seo[<%= key %>][description]" rows="2"
                        class="w-full rounded-2xl border border-slate-200 px-4 py-3 text-xs outline-none focus:border-primary-500 text-slate-600 font-medium"><%= content.seo[key] ? content.seo[key].description : '' %></textarea>
            </div>
          </div>
        </div>
      <% }) %>

    </div>

    <div class="border-t border-slate-150 pt-5 flex justify-end">
      <button type="submit" class="px-6 py-3 bg-primary-600 hover:bg-primary-500 text-white rounded-2xl text-sm font-bold transition shadow-lg shadow-primary-600/10">Save SEO Configurations</button>
    </div>
  </form>
</div>

<!-- Tabs Switching Script -->
<script>
  function switchTab(tabId) {
    // Hide all tab contents
    document.querySelectorAll('.tab-content').forEach(el => {
      el.classList.add('hidden');
    });
    
    // De-select all tab buttons
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.classList.remove('border-primary-600', 'text-primary-600', 'font-bold');
      btn.classList.add('border-transparent', 'text-slate-500', 'hover:text-slate-700', 'font-semibold');
    });

    // Show active tab
    const active = document.getElementById(tabId);
    if (active) {
      active.classList.remove('hidden');
    }

    // Highlight button
    event.currentTarget.classList.remove('border-transparent', 'text-slate-500', 'hover:text-slate-700', 'font-semibold');
    event.currentTarget.classList.add('border-primary-600', 'text-primary-600', 'font-bold');
  }
</script>

<%- include('partials/footer') %>
